PORT=3000
NODE_ENV=production
BASE_URL=https://seekho2wheeler.vercel.app
API_BASE_URL=

JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES_IN=8h

ADMIN_EMAIL=admin@seekhoacademy.com
ADMIN_PASSWORD=ChangeMe@Secure123

# --- Google Sheets (PRIMARY production database) ---
# 1. Create a Google Cloud service account + enable Sheets API
# 2. Download JSON key and save as: credentials/service-account.json  (recommended on Windows/Node 22)
# 3. Create a spreadsheet and share it with the service account email (Editor)
# 4. Run: npm run init-sheets -- --seed
GOOGLE_SHEETS_ENABLED=true
GOOGLE_SHEETS_ID=1muxLXxr3iCNtj5-phkJjma1v8ymng7Bw9lHrTlx5kCk

# Optional path override (defaults to ./credentials/service-account.json)
# GOOGLE_APPLICATION_CREDENTIALS=./credentials/service-account.json

# Mode C (Vercel recommended) — paste the ENTIRE service-account.json as one line:
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----\\n","client_email":"..."}

# Mode A (env) — only if you are NOT using the JSON file / JSON env:
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_REAL_KEY_HERE\n-----END PRIVATE KEY-----\n"

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
NOTIFY_EMAIL=admin@seekhoacademy.com

FACEBOOK_URL=
INSTAGRAM_URL=
YOUTUBE_URL=
WHATSAPP_NUMBER=9748481630

# --- Cloudinary (PRIMARY media storage for admin uploads) ---
# Create a free account at https://cloudinary.com → Dashboard → API Keys
# Google Sheets stores only the returned HTTPS image URL (never binary).
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_FOLDER=seekho
